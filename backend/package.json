{
  "name": "denyquiz-backend",
  "version": "3.0.0",
  "description": "API Robusta para o DenyQuiz com Banco de Dados Interno de 5000+ Perguntas, Sistema de Fallback e Persistência em PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:debug": "nodemon --inspect server.js",
    "prod": "NODE_ENV=production node server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:setup": "node scripts/setupDatabase.js",
    "db:backup": "node scripts/backupDatabase.js",
    "stats": "node scripts/showStats.js"
  },
  "keywords": [
    "quiz",
    "anime",
    "flutter",
    "api",
    "one-piece",
    "naruto",
    "dragon-ball",
    "jujutsu-kaisen",
    "demon-slayer",
    "attack-on-titan",
    "my-hero-academia",
    "death-note",
    "fullmetal-alchemist",
    "bleach",
    "hunter-x-hunter",
    "pokemon",
    "studio-ghibli",
    "cavaleiros-do-zodiaco",
    "sailor-moon",
    "chainsaw-man",
    "spy-x-family"
  ],
  "author": {
    "name": "DenyQuiz Team",
    "email": "contato@denyquiz.com",
    "url": "https://denyquiz.com"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/denyquiz/backend.git"
  },
  "bugs": {
    "url": "https://github.com/denyquiz/backend/issues"
  },
  "homepage": "https://github.com/denyquiz/backend#readme",
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "pg": "^8.11.3",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.1.1"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8",
    "utf-8-validate": "^6.0.3"
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "database.js",
      "scripts/"
    ],
    "ignore": [
      "node_modules/*",
      "scripts/backups/*"
    ],
    "delay": "1000",
    "env": {
      "NODE_ENV": "development",
      "PORT": 3000
    }
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2021": true,
      "jest": true
    },
    "extends": "airbnb-base",
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "script"
    },
    "rules": {
      "no-console": "off",
      "consistent-return": "off",
      "no-underscore-dangle": "off",
      "max-len": ["error", { "code": 120 }]
    }
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": true,
    "printWidth": 100
  },
  "config": {
    "port": 3000,
    "database": {
      "maxConnections": 20,
      "idleTimeout": 10000,
      "connectionTimeout": 5000
    },
    "quiz": {
      "questionsPerSession": 10,
      "defaultDifficulty": "medium"
    }
  }
}
